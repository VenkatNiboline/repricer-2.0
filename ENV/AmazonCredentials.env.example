# Copy this file to AmazonCredentials.env and fill in your values.

# Set to false to block all Amazon SP-API calls (reads, writes, catalog sync, sales ETL).
AMAZON_API_ENABLED=false

# --- Amazon SP-API ---
LWA_CLIENT_ID=amzn1.application-oa2-client.xxxxx
LWA_CLIENT_SECRET=xxxxx
LWA_REFRESH_TOKEN=Atzr|xxxxx
SELLER_ID=Axxxxxxxxxx

# --- Supabase (project: amazon-repricer) ---
SUPABASE_URL=https://mpdhzvklvyzjwxpvsfkw.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Dashboard → Project Settings → API → service_role (server only, never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=
# Shared secret for catalog sync Edge Function + pg_cron (openssl rand -hex 32)
CATALOG_CRON_SECRET=your-service-role-key
# Set to true to allow open self-registration (default: disabled)
ALLOW_SIGNUPS=false
